{% extends 'default/layout.html.twig' %}

{% block header %}
{{'un titre magnifique !' |title }} 
{% endblock %}

{% block content %}
<div>
    <table class="table">
        <tr>
            <th>Id</th>
            <th>Email</th>
            <th>subject</th>
            <th>message</th>
            <th>date</th>
        </tr>
        <tr>
            <td> {{ contact.id }} </td>
            <td> {{ contact.email }} </td>
            <td> {{ contact.subject }} </td>
            <td> {{ contact.message }} </td>
            <td> {{ contact.createdAt | date('d/m/Y H:i:s') }} </td>
        </tr>
    </table>
</div>
    
{% endblock %}

{% block body %}
{% endblock %}